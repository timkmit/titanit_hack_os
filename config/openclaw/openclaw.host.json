{
  "discovery": {
    "mdns": {
      "mode": "off"
    }
  },
  "session": {
    "dmScope": "per-channel-peer",
    "maintenance": {
      "mode": "warn",
      "pruneAfter": "30d",
      "maxEntries": 500
    }
  },
  "gateway": {
    "mode": "local",
    "controlUi": {
      "allowedOrigins": [
        "http://localhost:18789",
        "http://127.0.0.1:18789",
        "*"
      ],
      "dangerouslyDisableDeviceAuth": true
    }
  },
  "browser": {
    "enabled": true,
    "executablePath": "/usr/local/bin/openclaw-chromium",
    "defaultProfile": "openclaw",
    "headless": true,
    "noSandbox": true,
    "color": "#FF5A36",
    "ssrfPolicy": {
      "dangerouslyAllowPrivateNetwork": true
    },
    "profiles": {
      "openclaw": {
        "cdpPort": 18800,
        "color": "#FF5A36"
      }
    }
  },
  "tools": {
    "profile": "full",
    "allow": [
      "group:ui",
      "group:web"
    ],
    "web": {
      "fetch": {
        "enabled": true,
        "maxCharsCap": 50000
      },
      "search": {
        "enabled": false
      }
    }
  },
  "agents": {
    "defaults": {
      "workspace": "~/.openclaw/workspace",
      "timeoutSeconds": 900,
      "model": {
        "primary": "ollama/qwen2.5:14b"
      },
      "models": {
        "ollama/qwen2.5:14b": {
          "params": {
            "num_ctx": 32768
          }
        }
      }
    }
  },
  "models": {
    "mode": "merge",
    "providers": {
      "ollama": {
        "baseUrl": "https://grotesquely-admirable-grebe.cloudpub.ru",
        "apiKey": "ollama-local",
        "api": "ollama",
        "models": [
          {
            "id": "qwen2.5:14b",
            "name": "Qwen 2.5 14B",
            "reasoning": false,
            "input": [
              "text"
            ],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 131072,
            "maxTokens": 4096
          }
        ]
      }
    }
  },
  "plugins": {
    "entries": {
      "browser": {
        "enabled": true
      }
    }
  },
  "meta": {
    "lastTouchedVersion": "2026.4.2",
    "lastTouchedAt": "2026-04-05T04:03:41.311Z"
  }
}
